{
  "name": "apicup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:simulate": "tsx --env-file=.env.local scripts/simulate.ts",
    "db:reset": "tsx --env-file=.env.local scripts/reset-competition.ts --yes",
    "db:test-users": "tsx --env-file=.env.local scripts/test-users.ts",
    "db:go-live": "tsx --env-file=.env.local scripts/go-live.ts --yes",
    "db:add-group-stage": "tsx --env-file=.env.local scripts/add-group-stage.ts",
    "db:reset-group-stage": "tsx --env-file=.env.local scripts/reset-group-stage.ts",
    "db:ai-r32-picks": "tsx --env-file=.env.local scripts/ai-r32-picks.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
